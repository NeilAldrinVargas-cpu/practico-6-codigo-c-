#include <iostream>
#include <cmath> // Para usar M_PI y potencias si fuera necesario

using namespace std;

int main() {
    int opcion;
    double area, L, R, B, H;
    const double PI = 3.14159265;

    cout << "--- MENU DE CALCULO DE AREAS ---" << endl;
    cout << "1. Cuadrado (L * L)" << endl;
    cout << "2. Circulo (Pi * R^2)" << endl;
    cout << "3. Triangulo (B * H / 2)" << endl;
    cout << "Seleccione una opcion: ";
    cin >> opcion;

    // Estructura Switch para el menú
    switch (opcion) {
        case 1:
            cout << "Ingrese el lado (L): "; cin >> L;
            area = L * L;
            cout << "El area del cuadrado es: " << area << endl;
            break;

        case 2:
            cout << "Ingrese el radio (R): "; cin >> R;
            area = PI * (R * R);
            cout << "El area del circulo es: " << area << endl;
            break;

        case 3:
            cout << "Ingrese la base (B): "; cin >> B;
            cout << "Ingrese la altura (H): "; cin >> H;
            area = (B * H) / 2;
            cout << "El area del triangulo es: " << area << endl;
            break;

        default:
            cout << "Opcion no valida. Por favor intente de nuevo." << endl;
            break;
    }

    return 0;
}
